# Server Configuration
HOST=localhost
PORT=8000
ALLOW_CORS_URL=http://localhost:3000

#Jwt Securtiy
ACCESS_TOKEN_SECRET=bc63d848ca6e651b3b848bd96ef1ad1eb9b31afc9cad67ed5953efd023d02ffe
ACCESS_TOKEN_EXPIRATION=3d
REFRESH_TOKEN_SECRET=bc63d848ca6e651b3b848bd96ef1ad1eb9b31afc9cad67ed5953efd023d02ffe
REFRESH_TOKEN_EXPIRATION=30d

#Database Configuration
# Choose the engine: "postgres" (default), "mysql" (or "mariadb") or "sqlite".
DB_TYPE=postgres
# Used by postgres/mysql. Ignored by sqlite.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=turborepo
DB_SSL=true
# Used by sqlite only: path to the database file.
DB_DATABASE=./data/cms.sqlite

#Mail Configuration
MAIL_HOST=gmail
MAIL_USERNAME=
MAIL_PASSWORD=

#File System Configuration
# type file_system =  "s3" | "public"
FILE_SYSTEM=s3
FILE_MAX_SIZE=20971520#20Mb
# Plugin Marketplace
# URL of the marketplace catalog.json consumed by Admin → Marketplace.
# Defaults to the published OpenCMS plugin registry. Use a file: URL to point at
# a local checkout during development, e.g.
# file:///path/to/opencms-plugins/catalog.json
PLUGIN_MARKETPLACE_URL=https://raw.githubusercontent.com/nuvooo/opencms-plugins/main/catalog.json
